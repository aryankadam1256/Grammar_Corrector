# ============================================
# Grammar Correction System - Environment Variables
# ============================================
# Copy this file to .env and fill in your actual values.
# NEVER commit the actual .env file.

# ── API Configuration ────────────────────────────────
API_HOST=0.0.0.0
API_PORT=9000
API_WORKERS=1
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Model Paths ─────────────────────────────────────
# Path to fine-tuned FLAN-T5-Large LoRA adapter
MODEL_PATH=checkpoints/flan_t5_large_bea2019/llama_gec_lora

# Path to fine-tuned Llama 3.2-3B LoRA adapter
LLAMA32_MODEL_PATH=checkpoints/llama32_bea2019/llama_gec_lora

# Grammarly CoEdIT — downloaded automatically from HuggingFace Hub
COEDIT_PATH=grammarly/coedit-large

# ── Hugging Face ─────────────────────────────────────
# Required to download gated models (e.g. Llama 3.2-3B-Instruct)
# Get your token at: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# ── Experiment Tracking (optional) ──────────────────
# Used only during training, not inference
WANDB_API_KEY=your_wandb_api_key_here
WANDB_PROJECT=grammar-correction
